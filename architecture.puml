@startuml Medical Benefit Drug Policy Tracker - MLOps Architecture

!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam ArrowColor #444444
skinparam ArrowThickness 1.2

skinparam component {
  BackgroundColor #E8F4FD
  BorderColor #2980B9
  FontColor #1A252F
}
skinparam database {
  BackgroundColor #FEF9E7
  BorderColor #F39C12
  FontColor #1A252F
}
skinparam package {
  BackgroundColor #F9F9F9
  BorderColor #BDC3C7
  FontStyle bold
  FontColor #2C3E50
}
skinparam actor {
  BackgroundColor #D5F5E3
  BorderColor #27AE60
}
skinparam note {
  BackgroundColor #FDFEFE
  BorderColor #AAB7B8
  FontSize 10
}

title <b>Medical Benefit Drug Policy Tracker — MLOps Architecture</b>

' ══════════════════════════════════════════════════════════════
' ACTORS
' ══════════════════════════════════════════════════════════════
actor "Policy Analyst" as analyst
actor "ML Engineer"    as mleng

' ══════════════════════════════════════════════════════════════
' FRONTEND
' ══════════════════════════════════════════════════════════════
package "Frontend  (Streamlit :8501)" #EBF5FB {
  component "App Tabs\n──────────────────────────\nUpload | Ask AI | Coverage Grid\nCompare Plans | Change Tracker" as app_tabs
  component "MLOps Dashboard\n──────────────────────────\nLLM Cost & Latency charts\nExtraction Quality badges\nDrift Alert feed\nCorrections review\nA/B Test results\nPrompt Manager" as mlops_dashboard
}

analyst  --> app_tabs
mleng    --> mlops_dashboard

' ══════════════════════════════════════════════════════════════
' API LAYER
' ══════════════════════════════════════════════════════════════
package "API Layer  (FastAPI :8000)" #EBF5FB {
  component "/ingest\n/query\n/compare\n/policies" as core_api
  component "/mlops/prompts\n/mlops/observability\n/mlops/quality\n/mlops/drift\n/mlops/corrections\n/mlops/cache\n/mlops/reextract\n/mlops/ab_tests" as mlops_api
}

app_tabs       --> core_api   : HTTP REST
mlops_dashboard --> mlops_api : HTTP REST

' ══════════════════════════════════════════════════════════════
' [1] PROMPT REGISTRY  ← MLOps
' ══════════════════════════════════════════════════════════════
package "① Prompt Registry" #FEF9E7 {
  component "Prompt Version Store\n────────────────────────\nprompt_name | version_tag\nstatus: draft→staging→prod\nsystem_prompt | user_prompt\ndeployed_at | notes" as prompt_registry

  component "Promotion Workflow\n────────────────────────\ndraft → staging → production\nrollback to prior version\nquality gate check before\npromotion" as prompt_promote

  prompt_registry --> prompt_promote : lifecycle\nmanagement
}

note right of prompt_registry
  All hardcoded strings removed.
  Every Claude call loads
  the active production prompt
  by name at call time.
end note

' ══════════════════════════════════════════════════════════════
' INGESTION PIPELINE (with MLOps hooks)
' ══════════════════════════════════════════════════════════════
package "Ingestion Pipeline  (with MLOps hooks)" #E9F7EF {
  component "Pre-extraction\nValidator\n──────────────\nFile parseable?\nText non-empty?\nMin chars check" as pre_validator

  component "PDF Parser\n(pdfplumber)\n──────────────\nPage text + tables\n800-tok chunks\n100-tok overlap" as pdf_parser

  component "Claude Extractor\n(reads from Prompt Registry)\n──────────────────────────────\nActive production prompt fetched\nfrom prompt_versions table\nBatch by 60k chars\nJSON retry on failure" as extractor

  component "Post-extraction\nValidator  ②\n──────────────────\nSchema completeness score\nRequired field presence\nEnum validity check\nPA/step consistency\nFlags anomalies" as post_validator

  component "Ingestion\nOrchestrator\n──────────────\nWires steps 1–5\nStores prompt_version_id\non every CoveragePolicy\nCalls drift detector\nInvalidates query cache" as pipeline

  core_api --> pipeline
  pipeline --> pre_validator
  pre_validator --> pdf_parser
  pdf_parser --> extractor
  extractor --> post_validator
}

extractor --> prompt_registry : fetch active\nproduction prompt

' ══════════════════════════════════════════════════════════════
' [2] LLM OBSERVABILITY  ← MLOps
' ══════════════════════════════════════════════════════════════
package "② LLM Observability  (llm_logger.py)" #FDEDEC {
  component "tracked_call() wrapper\n────────────────────────────\ncall_type | model | prompt_version_id\ninput_tokens | output_tokens\nlatency_ms | cost_usd\nstop_reason | error\n→ appends to llm_call_log" as llm_logger

  note right of llm_logger
    Every client.messages.create()
    call routes through here.
    Computes cost:
    input × $3/M + output × $15/M
    (claude-sonnet-4-6 pricing)
  end note
}

extractor --> llm_logger : all extraction calls
' (RAG also connects below)

' ══════════════════════════════════════════════════════════════
' CLAUDE AI LAYER
' ══════════════════════════════════════════════════════════════
package "AI Layer  (Anthropic SDK)" #E8F4FD {
  component "Claude claude-sonnet-4-6\n────────────────────────────\nExtraction  →  JSON drug data\nIntent extraction  →  query type\nRAG generation  →  cited answer" as claude

  component "RAG Engine\n(claude_rag.py)\n────────────────\n① Cache lookup\n② Intent extract\n③ SQL pre-filter\n④ Vector search\n⑤ Augmented gen\n⑥ RAG evaluation\n⑦ Cache store" as rag_engine
}

llm_logger --> claude : all API calls\n(logged transparently)
core_api --> rag_engine : /query/ask
rag_engine --> prompt_registry : fetch active\nRAG prompt
rag_engine --> llm_logger : intent + gen calls

' ══════════════════════════════════════════════════════════════
' [3] EXTRACTION QUALITY EVALUATOR  ← MLOps
' ══════════════════════════════════════════════════════════════
package "③ Extraction Quality  (extraction_evaluator.py)" #E9F7EF {
  component "Quality Scorer\n──────────────────────────────\nschema_completeness_avg  0–1\nrequired_fields_pass_rate 0–1\nenum_validity_rate        0–1\nanomaly_count\n─────────────────────────\nIf completeness < 0.5:\n  status → 'low_quality'\n  (routed to review queue)" as extraction_eval
}

post_validator --> extraction_eval : score results
extraction_eval --> pipeline : quality gate\npass/fail signal

' ══════════════════════════════════════════════════════════════
' [4] RAG QUALITY EVALUATOR  ← MLOps
' ══════════════════════════════════════════════════════════════
package "④ RAG Quality  (rag_evaluator.py)" #E9F7EF {
  component "RAG Scorer\n────────────────────────────\ncontext_relevance  (token overlap)\ngroundedness_score (citation coverage)\nhuman_rating 1–5 (from analyst)\nreturns rag_score_id\nin AskResponse" as rag_eval
}

rag_engine --> rag_eval : score every\nRAG response
analyst --> rag_eval : thumbs up/down\nfeedback widget

' ══════════════════════════════════════════════════════════════
' [5] DATA DRIFT DETECTOR  ← MLOps
' ══════════════════════════════════════════════════════════════
package "⑤ Data Drift Detector  (drift_detector.py)" #FEF9E7 {
  component "Drift Signals\n──────────────────────────────\nnew_drug_class  (never seen before)\npa_rate_shift   (>20% change vs history)\ncoverage_status_distribution_shift\nextraction_volume_drop\n─────────────────────────\nseverity: info | warning | critical\nStored in drift_events table" as drift_detector
}

pipeline --> drift_detector : called after\nevery ingest

' ══════════════════════════════════════════════════════════════
' [6] HUMAN FEEDBACK  ← MLOps
' ══════════════════════════════════════════════════════════════
package "⑥ Human-in-the-Loop  (analyst_corrections)" #FEF9E7 {
  component "Analyst Correction\n──────────────────────────────\nfield_name | original_value\ncorrected_value | reason\napplied (bool)\n─────────────────────────\nCorrections feed back into\nprompt improvement workflow.\nApply endpoint writes\ncorrected_value to coverage_policies" as hitl
}

analyst --> hitl : correct extraction\nerrors in UI

' ══════════════════════════════════════════════════════════════
' [7] SEMANTIC QUERY CACHE  ← MLOps
' ══════════════════════════════════════════════════════════════
package "⑦ Semantic Query Cache  (query_cache_service.py)" #E9F7EF {
  component "Cache Layer\n──────────────────────────────\nKey: SHA256(normalized_question\n      + sorted_plan_ids)\nHit → return cached answer\nMiss → run full RAG pipeline\nTTL: 7 days (configurable)\nInvalidated on new ingest\nfor affected plan" as cache

  note bottom of cache
    Eliminates redundant
    Claude calls for repeated
    questions. Returns
    cache_hit: bool in response.
  end note
}

rag_engine --> cache : check before\nClaude call
pipeline --> cache : invalidate plan's\ncache on new ingest

' ══════════════════════════════════════════════════════════════
' [8] RE-EXTRACTION JOBS  ← MLOps
' ══════════════════════════════════════════════════════════════
package "⑧ Re-extraction Jobs  (reextraction_jobs)" #FDEDEC {
  component "Job Queue\n──────────────────────────────\ntrigger_reason:\n  prompt_promotion\n  model_change\n  low_quality_score\n  manual\nstatus: queued → running\n       → complete | failed\nAuto-queued on prompt\npromotion to production" as reextract
}

prompt_promote --> reextract : auto-queue all docs\nwhen prompt promoted
extraction_eval --> reextract : queue low-quality\ndocs for re-run

' ══════════════════════════════════════════════════════════════
' [9] EMBEDDING MODEL VERSIONING  ← MLOps
' ══════════════════════════════════════════════════════════════
package "⑨ Embedding Versioning  (embedding_model_versions)" #FEF9E7 {
  component "Embedding Model Tracker\n──────────────────────────────\nmodel_name | model_version\ndimensions | is_active\n─────────────────────────\nCollection name derived from\nactive model slug:\n  policy_chunks_<model_slug>\nPrevents mixing incompatible\nembedding spaces\nActivating new model →\nauto-queues re-embed jobs" as embed_versioning
}

' ══════════════════════════════════════════════════════════════
' [10] A/B PROMPT TESTING  ← MLOps
' ══════════════════════════════════════════════════════════════
package "⑩ A/B Prompt Testing  (ab_tester.py)" #FDEDEC {
  component "A/B Test Runner\n──────────────────────────────\nRun extraction twice on\nsame doc with prompt A & B\nCompute diff:\n  drugs unique to A/B\n  field value differences\nAnalyst sets winner\nWinner promoted to prod\nBoth calls logged via\nllm_call_log" as ab_tester
}

mleng --> ab_tester : create + run\nA/B tests
ab_tester --> prompt_registry : winner → promote
ab_tester --> llm_logger : both extraction\ncalls logged

' ══════════════════════════════════════════════════════════════
' STORAGE LAYER (extended for MLOps)
' ══════════════════════════════════════════════════════════════
package "Storage Layer  (Extended)" {
  database "SQLite  (antonrx.db)\n───────────────────────────\n<b>Original tables:</b>\nhealth_plans  |  policy_documents\ndrugs  |  coverage_policies\nprior_auth_criteria  |  step_therapy\npolicy_change_log  |  document_chunks\n\n<b>MLOps tables added:</b>\nprompt_versions\nllm_call_log\nextraction_quality_scores\nrag_quality_scores\ndrift_events\nanalyst_corrections\nquery_cache\nreextraction_jobs\nembedding_model_versions\nab_test_runs\n\n<b>Column additions:</b>\ncoverage_policies.extraction_prompt_version_id\npolicy_documents.extraction_score_id\ndocument_chunks.embedding_model_id" as sqlite

  database "ChromaDB  (versioned)\n─────────────────────────\nCollection name derived\nfrom active embedding\nmodel slug:\npolicy_chunks_<model_slug>\n\nMetadata per chunk:\ndoc_id | plan_id | plan_name\nquarter | page_num\nembedding_model_id" as chromadb
}

' ── Storage connections ────────────────────────────────
pipeline    --> sqlite       : write drugs, policies,\nchunks, PA criteria
extractor   --> chromadb     : embed + store chunks
rag_engine  --> chromadb     : similarity search
rag_engine  --> sqlite       : SQL pre-filter + join
llm_logger  --> sqlite       : append llm_call_log rows
extraction_eval --> sqlite   : write quality scores
rag_eval    --> sqlite       : write RAG scores
drift_detector --> sqlite    : write drift_events
hitl        --> sqlite       : analyst corrections
cache       --> sqlite       : read/write query_cache
reextract   --> sqlite       : job queue management
embed_versioning --> chromadb : collection per model
embed_versioning --> sqlite  : model version registry
ab_tester   --> sqlite       : ab_test_runs

' ══════════════════════════════════════════════════════════════
' MLOPS FEEDBACK LOOPS (highlighted flows)
' ══════════════════════════════════════════════════════════════

note top of prompt_promote
  <b>Feedback Loop A — Prompt Improvement</b>
  1. Analyst submits corrections  ⑥
  2. ML Engineer sees patterns in corrections
  3. Edits prompt → draft in Prompt Registry  ①
  4. A/B Tests new vs old prompt on sample docs  ⑩
  5. Sets winner, promotes to production
  6. Re-extraction jobs auto-queued for all docs  ⑧
end note

note bottom of rag_eval
  <b>Feedback Loop B — RAG Quality</b>
  Analyst thumbs up/down → human_rating stored
  Aggregated score monitored on MLOps Dashboard
  Low scores trigger prompt review in Loop A
end note

note right of drift_detector
  <b>Feedback Loop C — Data Drift</b>
  New drug class detected →
  DriftEvent (severity=warning)
  ML Engineer reviews extraction
  quality for the new class,
  updates prompt if needed (Loop A)
end note

' ══════════════════════════════════════════════════════════════
' LEGEND
' ══════════════════════════════════════════════════════════════
legend right
  |= Color |= Layer |
  | <#E8F4FD> | Application (API + AI) |
  | <#E9F7EF> | Observability / Quality |
  | <#FEF9E7> | Versioning / Registry |
  | <#FDEDEC> | Pipeline Control |
  Numbers ①–⑩ = MLOps components
endlegend

@enduml
