package "AI Layer  (Anthropic SDK вЂ” claude-sonnet-4-6)" #E8F4FD {
  component "Claude API\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\ncall_type=extraction:\n  JSON drug schema per batch\n  indication-specific step therapy\n  source_page + source_text\n  benefit_side + data_completeness\ncall_type=intent:\n  {drug_name, plan_names, query_type}\ncall_type=rag_generation:\n  cited prose answer\ncall_type=extraction_retry:\n  JSON correction on decode fail" as claude
